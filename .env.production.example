# Database Configuration
POSTGRES_DB=smartfinance
POSTGRES_USER=smartfinance
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
RABBITMQ_USER=smartfinance
RABBITMQ_PASSWORD=CHANGE_ME_STRONG_RABBITMQ_PASSWORD_HERE

# JWT Secrets (CHANGE ALL OF THESE!)
# Generate with: openssl rand -base64 32
JWT_ACCESS_SECRET=CHANGE_ME_32_CHARS_MINIMUM_RANDOM_STRING
JWT_REFRESH_SECRET=CHANGE_ME_32_CHARS_MINIMUM_RANDOM_STRING
JWT_SECRET_KEY=CHANGE_ME_32_CHARS_MINIMUM_RANDOM_STRING

# CORS Configuration
# For Lightsail IP: http://YOUR_LIGHTSAIL_IP
# For domain: https://your-domain.com
ALLOWED_ORIGINS=http://YOUR_LIGHTSAIL_IP,https://YOUR_DOMAIN_IF_ANY

# Frontend API URLs
# Replace YOUR_LIGHTSAIL_IP with your actual IP
NEXT_PUBLIC_API_URL=http://YOUR_LIGHTSAIL_IP/api/v1
NEXT_PUBLIC_SIGNALR_URL=http://YOUR_LIGHTSAIL_IP/financehub
NEXT_PUBLIC_PAYMENT_API_URL=http://YOUR_LIGHTSAIL_IP/api/v1/payments

# Production Settings
NODE_ENV=production
ASPNETCORE_ENVIRONMENT=Production
DATABASE_URL=postgres://smartfinance:CHANGE_ME_STRONG_PASSWORD_HERE@postgres:5432/smartfinance
DB_SSL=false
COOKIE_SECURE=true
COOKIE_SAMESITE=Lax
