# SmartFinance Environment Variables Template
# Copy this file to a local .env (never commit secrets)

NODE_ENV=development
ASPNETCORE_ENVIRONMENT=Development
TRUST_PROXY=true
BODY_LIMIT_BYTES=1048576

# Core infrastructure
POSTGRES_DB=smartfinance
POSTGRES_USER=smartfinance
POSTGRES_PASSWORD=CHANGE_THIS_TO_A_STRONG_LOCAL_DB_PASSWORD
RABBITMQ_USER=smartfinance
RABBITMQ_PASSWORD=CHANGE_THIS_TO_A_STRONG_LOCAL_RABBITMQ_PASSWORD

# JWT Configuration (CHANGE THESE SECRETS!)
JWT_ACCESS_SECRET=CHANGE_THIS_TO_A_RANDOM_64_CHAR_HEX_STRING
JWT_REFRESH_SECRET=CHANGE_THIS_TO_A_RANDOM_64_CHAR_HEX_STRING
JWT_ISSUER=SmartFinance
JWT_AUDIENCE=SmartFinanceUsers
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
JWT_SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_64_CHAR_HEX_STRING

# Cookie Security
COOKIE_ACCESS_NAME=sf_at
COOKIE_REFRESH_NAME=sf_rt
COOKIE_CSRF_NAME=sf_csrf
COOKIE_DOMAIN=
COOKIE_SECURE=false
COOKIE_SAMESITE=Lax

# CORS
ALLOWED_ORIGINS=http://localhost:3000

# Rate limits
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_IP=200
RATE_LIMIT_MAX_USER=120
RATE_LIMIT_MAX_LOGIN=10

# Service URLs (configured for production)
NEXT_PUBLIC_API_URL=/api/v1
NEXT_PUBLIC_SIGNALR_URL=/financehub
NEXT_PUBLIC_PAYMENT_API_URL=/api/v1/payments

# Backend internal URL (SSR/proxy)
BACKEND_URL=http://localhost:5000

# Runtime flags
DB_SSL=false
AUTO_MIGRATE=true
SEED_DEMO_DATA=false
ALLOW_SEED_PROD=false
